generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductCollection {
  LATEST_DROP
  ARCHIVE
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
  REFUNDED
}

model Product {
  id                 String          @id @default(cuid())
  title              String
  slug               String          @unique
  description        String?
  collection         ProductCollection @default(LATEST_DROP)
  price_kobo         Int
  compare_at_kobo    Int?
  currency           String          @default("NGN")
  inventory_qty      Int             @default(0)
  active             Boolean         @default(true)
  tags               String[]
  images             String[]
  
  // Product variations (sizes)
  variants           ProductVariant[]
  
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  order_items        OrderItem[]
}

model ProductVariant {
  id              String   @id @default(cuid())
  product_id      String
  size            String   // e.g., "S", "M", "L", "XL", "XXL"
  inventory_qty   Int      @default(0)
  price_kobo      Int?     // Optional: override product price for this size
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  product         Product  @relation(fields: [product_id], references: [id])
  order_items     OrderItem[]

  @@index([product_id])
}

model Order {
  id                      String        @id @default(cuid())
  order_number            String        @unique
  status                  OrderStatus   @default(PENDING)
  currency                String        @default("NGN")
  subtotal_kobo           Int
  shipping_kobo           Int
  total_kobo              Int

  customer_email          String
  customer_phone          String?
  shipping_address_json   Json

  paystack_reference      String        @unique
  paystack_transaction_id String?
  paid_at                 DateTime?
  
  // Delivery tracking
  tracking_number         String?
  delivery_notes          String?
  shipped_at              DateTime?
  delivered_at            DateTime?

  created_at              DateTime      @default(now())
  updated_at              DateTime      @updatedAt

  items                   OrderItem[]
  payment_events          PaymentEvent[]

  @@index([status])
  @@index([customer_email])
  @@index([created_at])
}

model OrderItem {
  id              String   @id @default(cuid())
  order_id        String
  product_id      String
  variant_id      String?
  title_snapshot  String
  size_snapshot   String?  // Store the size at time of order
  unit_price_kobo Int
  quantity        Int
  variant_json    Json?
  line_total_kobo Int

  order           Order    @relation(fields: [order_id], references: [id])
  product         Product  @relation(fields: [product_id], references: [id])
  variant         ProductVariant? @relation(fields: [variant_id], references: [id])

  @@index([order_id])
  @@index([product_id])
}

model PaymentEvent {
  id          String   @id @default(cuid())
  order_id    String
  reference   String
  event_type  String
  payload_json Json
  created_at  DateTime @default(now())

  order       Order    @relation(fields: [order_id], references: [id])

  @@index([order_id])
  @@index([reference])
}


enum UserRole {
  ADMIN
  STAFF
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password_hash String
  role          UserRole  @default(ADMIN)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([role])
}
model Subscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([active])
}